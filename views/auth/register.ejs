<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  >

  <!-- 全站公共样式 -->
  <link rel="stylesheet" href="/css/style.css">

  <!-- 登录和注册页面专用样式 -->
  <link rel="stylesheet" href="/css/auth.css">

  <title>Register</title>
</head>

<body>

  <%- include("../partials/navbar") %>

  <main class="auth-page register-page">

    <section class="auth-card register-card">

      <div class="auth-card-content">

        <h1>Register</h1>

        <p class="description">
          Create an account to share and manage clothing items.
        </p>


        <!-- 后端传来错误信息时显示 -->
        <% if (
          typeof error !== "undefined" &&
          error
        ) { %>

          <div class="message error-message">
            <%= error %>
          </div>

        <% } %>


        <form
          action="/register"
          method="POST"
          class="auth-form"
        >

          <!-- Username -->
          <div class="form-group">

            <label for="username">
              Username
            </label>

            <input
              type="text"
              id="username"
              name="username"

              value="<%=
                typeof values !== "undefined" &&
                values.username
                  ? values.username
                  : ""
              %>"

              placeholder="Enter your username"

              minlength="2"
              maxlength="30"
              autocomplete="username"
              required
            >

          </div>


          <!-- Email -->
          <div class="form-group">

            <label for="email">
              Email
            </label>

            <input
              type="email"
              id="email"
              name="email"

              value="<%=
                typeof values !== "undefined" &&
                values.email
                  ? values.email
                  : ""
              %>"

              placeholder="Enter your email"

              autocomplete="email"
              required
            >

          </div>


          <!-- Password -->
          <div class="form-group">

            <div class="form-label-row">

              <label for="password">
                Password
              </label>

              <small>
                At least 6 characters
              </small>

            </div>

            <input
              type="password"
              id="password"
              name="password"

              placeholder="Enter your password"

              minlength="6"
              autocomplete="new-password"
              required
            >

          </div>


          <!-- Confirm Password -->
          <div class="form-group">

            <label for="confirmPassword">
              Confirm Password
            </label>

            <input
              type="password"
              id="confirmPassword"
              name="confirmPassword"

              placeholder="Enter your password again"

              minlength="6"
              autocomplete="new-password"
              required
            >

          </div>


          <button
            type="submit"
            class="auth-button"
          >
            Register
          </button>

        </form>


        <p class="auth-link">

          Already have an account?

          <a href="/login">
            Log in
          </a>

        </p>

      </div>

    </section>

  </main>

  <%- include("../partials/footer") %>

</body>
</html>